{
  "name": "mechvibes-x",
  "productName": "Mechvibes X",
  "version": "1.0.0",
  "description": "Play mechanical keyboard sounds as you type. (cleaned fork of Mechvibes)",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:all": "electron-builder -wml",
    "build:win": "electron-builder -w",
    "build:mac": "electron-builder -m",
    "build:linux": "electron-builder -l",
    "build:clean": "node tools/clean-dist.js"
  },
  "keywords": [],
  "license": "MIT",
  "author": "",
  "iohook": {
    "targets": [
      "electron-87"
    ],
    "platforms": [
      "win32",
      "darwin",
      "linux"
    ],
    "arches": [
      "x64"
    ]
  },
  "build": {
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.png"
    },
    "mac": {
      "category": "public.app-category.entertainment",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.png"
    },
    "linux": {
      "category": "Utility",
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "snap",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.png"
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "easy-volume": "^1.1.0",
    "electron-log": "^4.4.8",
    "electron-store": "^6.0.0",
    "fs-extra": "^9.0.1",
    "glob": "^7.1.6",
    "howler": "^2.2.4",
    "iohook": "^0.9.3",
    "mime-types": "^2.1.35"
  },
  "devDependencies": {
    "electron": "^12.2.3",
    "electron-builder": "^24.13.3"
  }
}
